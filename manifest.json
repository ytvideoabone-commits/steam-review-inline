{
  "manifest_version": 3,
  "name": "Steam Search Review Inline",
  "version": "1.0.0",
  "description": "Steam arama sonuçlarında Son İncelemeler ve Bütün İncelemeler bilgisini gösterir.",
  "permissions": [],
  "host_permissions": [
    "https://store.steampowered.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://store.steampowered.com/search/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}